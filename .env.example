# =====================================================================
# Configuration du bot Discord "bot_logs" (World of Warcraft / WCL)
# Copiez ce fichier en `.env` et renseignez vos valeurs réelles.
# Le fichier `.env` ne doit JAMAIS être committé (il est dans .gitignore).
# =====================================================================

# --- Discord (obligatoire) ---
# Jeton du bot Discord (Developer Portal > Bot > Reset Token).
DISCORD_TOKEN=

# ID du serveur (guild) où les slash-commands sont synchronisées.
GUILD_ID=

# ID du canal de type Forum dans lequel les fils de run sont créés.
FORUM_CHANNEL_ID=

# --- Warcraft Logs API v2 (obligatoire) ---
# Client OAuth2 "v2 API" créé sur https://www.warcraftlogs.com/api/clients/
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=

# --- Options (facultatif) ---
# Mode debug : 1 = logs verbeux (jamais de secrets). 0 ou absent = normal.
DEBUG=0

# Niveau de clé M+ minimum pour qu'un run crée un fil (ex: 15 => +15 et plus).
MIN_KEY_LEVEL=2

# Rôles Discord autorisés à utiliser les commandes sensibles (/logs).
# Liste d'IDs de rôles séparés par des virgules. Vide = tout le monde.
ALLOWED_ROLE_IDS=

# Chemin du fichier SQLite (par défaut: data/bot_logs.db).
DATABASE_PATH=data/bot_logs.db

# ID d'un canal Discord où relayer les erreurs (facultatif). Vide = fichier seul.
LOG_CHANNEL_ID=

# Fichier de log (par défaut: logs/bot.log). Vide = console seulement.
LOG_FILE=logs/bot.log

# Publier les liens WoWAnalyzer pour les raids (1 lien par boss). 1 = oui.
WOWANALYZER_RAID_LINKS=1

# --- Annonce automatique des nouveaux records (facultatif) ---
# Canal où annoncer chaque nouveau record de donjon (saison en cours).
# Vide = annonces désactivées.
RECORDS_CHANNEL_ID=

# --- Récap hebdomadaire automatique (facultatif) ---
# Canal où poster le récap M+ chaque semaine. Vide = récap désactivé.
RECAP_CHANNEL_ID=
# Jour du récap : 0 = lundi … 6 = dimanche (défaut 0).
RECAP_WEEKDAY=0
# Heure locale du récap, 0-23 (défaut 10).
RECAP_HOUR=10

# --- Auto-détection des liens Warcraft Logs (facultatif) ---
# IDs des canaux où coller un lien WCL crée automatiquement les fils (sans /logs).
# Liste séparée par des virgules. Vide = désactivé.
# ⚠️ Si renseigné, activez l'intent privilégié « Message Content » dans le
# Developer Portal Discord (onglet Bot > Privileged Gateway Intents).
AUTO_DETECT_CHANNEL_IDS=

# --- Administration : rôles responsables (facultatif) ---
# IDs des rôles autorisés aux commandes d'admin (gestion des saisons, à venir :
# /lier-admin). Liste séparée par des virgules (ex. Membre du conseil, Officier).
# Vide = repli sur la permission Discord « Gérer le serveur ».
ADMIN_ROLE_IDS=

# --- Leaderboard compétitif : auto-match des joueurs (facultatif) ---
# Affiche le pseudo Discord des joueurs présents sur le serveur sous chaque clé
# record du /leaderboard. La liaison manuelle (/lier) fonctionne toujours ; ce
# réglage active EN PLUS la correspondance automatique nom de perso ↔ pseudo.
# ⚠️ À 1/true, activez l'intent privilégié « Server Members » dans le Developer
# Portal Discord (onglet Bot > Privileged Gateway Intents) : sans cela, la
# connexion du bot échouera. Défaut 0 (désactivé).
ENABLE_MEMBER_MATCHING=0

# --- Supervision & sauvegarde (facultatif) ---
# Fichier de battement de cœur touché chaque minute (lu par le healthcheck Docker).
HEARTBEAT_FILE=data/heartbeat
# Dossier des sauvegardes SQLite quotidiennes. Vide = sauvegardes désactivées.
BACKUP_DIR=data/backups
# Nombre de sauvegardes conservées (rotation). Défaut 7.
BACKUP_KEEP=7